# ── templates/mediacalendar.html ───────────────────────────────────────
msgid "Media Calendar"
msgstr "Media Kalender"

msgid "Saved TMDB filters as calendars, curated lists, and upcoming releases at a glance."
msgstr "Gespeicherte TMDB-Filter als Kalender, kuratierte Listen und kommende Veröffentlichungen auf einen Blick."

msgid "TMDB is not configured yet. Media Calendar needs the CineInfo TMDB connection to look up movies and shows."
msgstr "TMDB ist noch nicht konfiguriert. Media Kalender benötigt die CineInfo-TMDB-Anbindung, um Filme und Serien nachzuschlagen."

msgid "Open Integrations settings"
msgstr "Integrationseinstellungen öffnen"

msgid "My Calendars"
msgstr "Meine Kalender"

msgid "My Lists"
msgstr "Meine Listen"

msgid "Settings"
msgstr "Einstellungen"

msgid "New calendar"
msgstr "Neuer Kalender"

msgid "New list"
msgstr "Neue Liste"

msgid "Planned Downloads"
msgstr "Geplante Downloads"

msgid "Releases flagged for automatic download once they become available -- checked hourly from their release date on."
msgstr "Veröffentlichungen, die für den automatischen Download vorgemerkt sind, sobald sie verfügbar sind -- ab dem Erscheinungsdatum stündlich geprüft."

msgid "Cancel"
msgstr "Abbrechen"

msgid "Save"
msgstr "Speichern"

