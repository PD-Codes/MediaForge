# ── templates/example_integration.html ─────────────────────────────────
msgid "Example Integration"
msgstr "Beispiel-Integration"

msgid "A small demo page showing placeholder items loaded from this integration's own cached data source."
msgstr "Eine kleine Demoseite mit Platzhalter-Einträgen aus der eigenen zwischengespeicherten Datenquelle dieser Integration."

msgid "Loading items…"
msgstr "Einträge werden geladen…"

msgid "No items could be loaded right now. Please try again later."
msgstr "Es konnten gerade keine Einträge geladen werden. Bitte versuche es später erneut."

# ── __init__.py: register_thirdparty(...) card shown in Integrations → Third Party ──
msgid "Demo"
msgstr "Demo"

msgid "Menu"
msgstr "Menü"

msgid "A minimal, self-contained reference integration that demonstrates the thirdparties/ plug-in contract end to end: its own Blueprint, page, cached data source, and translation catalog. Safe to enable — it only ever shows local placeholder data, no external network calls."
msgstr "Eine minimale, in sich geschlossene Referenz-Integration, die den thirdparties/-Plug-in-Vertrag vollständig zeigt: eigenes Blueprint, eigene Seite, eigene zwischengespeicherte Datenquelle und eigener Übersetzungskatalog. Gefahrlos aktivierbar — es werden ausschließlich lokale Platzhalterdaten angezeigt, keine externen Netzwerkaufrufe."

msgid "Enable Example Integration"
msgstr "Beispiel-Integration aktivieren"

msgid "Adds an \"Example Integration\" entry under Discover in the sidebar."
msgstr "Fügt einen \"Beispiel-Integration\"-Eintrag unter Entdecken in der Seitenleiste hinzu."
